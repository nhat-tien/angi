{
    port = 4000 - 20;
    routes = [
       {
           method = "GET";
           path = "/product/{name}";
           handler = () =>
           let
              product = sqlQuery("SELECT * FROM product p where p.name", name);
           in
              view(product, "./view/product")
           ;
       },
       {
           method = "GET";
           path = "/hello";
           handler = () => htmlTemplate("./index.html");
       },
       {
           method = "GET";
           path = "/json-test/{name}";
           handler = (req) => json({
               name = req.path.name;
               message = "Hello";
           });
       }
    ];
    static = {
      prefix = "/assets";
      dir = "./assets";
    };
}
