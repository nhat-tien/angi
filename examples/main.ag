{
    port = 4000 - 20;
    routes = [
       {
           path = "/";
           handler = () => html("<h1>Hello</h1>");
       },
       {
           path = "/hello";
           handler = () => htmlTemplate("./index.html");
       },
       {
           path = "/json-test";
           handler = () => json({
               name = "Tien";
               message = "Hello";
           });
       }
    ];
    static = {
      prefix = "/assets";
      dir = "./assets";
    };
}
