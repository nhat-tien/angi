

table Request { body: number }

enum Result { }


let
  html = import("lib.html");
in
{
    port = 3030;
    routes = [
       {
           path = "/";
           handler = () => "Hello world";
       },
       {
           path = "/id:int";
           handler = (id) => html("<p>Hello {id}</p>");
       },
       {
           path = "/id:int";
           handler = ({ data }) =>
              data
              |> validator(data)
              |> then(data =>
                    db.table("denkjn").insert(data)
                 )
              |> map(data => successMessage())
              |> orElse(e => error())
      }
    ];
};

